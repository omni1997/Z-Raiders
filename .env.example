# Copy to .env and fill in real values (never commit .env).

# PostgreSQL connection (used by docker-compose, and by db.js in local dev)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=zraiders
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SMTP credentials used to send password-reset emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-address@gmail.com

# Base URL used to build the reset-password link sent by email (nginx serves on 8080 in docker-compose)
APP_BASE_URL=http://localhost:3000
